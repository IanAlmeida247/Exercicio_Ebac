<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Formulário de Cadastro</title>
</head>
<body>
    <h1>Formulario para seu Cadastro</h1>
    <form>
        <label for="text">Seu Nome</label>
        <input  id="text" type="text">
        <br />
        <label for="e-mail">Seu e-mail</label>
        <input  id="e-mail" type="email"/>
        <br />
        <label for="Sua Senha">Sua senha</label>
        <input  id="Sua Senha" type="password"/>
        <br />
        <button type="submit">
            Cadastrar
        </button>
        <button type="reset">
            Limpar
        </button>

    </form>        
    
</body>
</html>
